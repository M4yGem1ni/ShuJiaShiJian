{
  "name": "shujiashijian-backend",
  "version": "1.0.0",
  "description": "\u6d59\u6c5f\u7701\u7ebf\u4e0a\u6276\u8d2b\u52df\u6350\u5e73\u53f0 - \u540e\u7aef",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:prod": "NODE_ENV=production node dist/app.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "release": "cd ../frontend && npm run build && cd ../backend && cp -r ../frontend/dist/* public/ && npm run build && echo 'Release build complete'",
    "pkg:linux-x64": "npx pkg dist/app.js --target node22-linux-x64 --output ../shujiashijian-linux-x64",
    "pkg:linux-arm64": "npx pkg dist/app.js --target node22-linux-arm64 --output ../shujiashijian-linux-arm64",
    "pkg:darwin-x64": "npx pkg dist/app.js --target node22-darwin-x64 --output ../shujiashijian-darwin-x64",
    "pkg:darwin-arm64": "npx pkg dist/app.js --target node22-darwin-arm64 --output ../shujiashijian-darwin-arm64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@yao-pkg/pkg": "^6.21.0",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/.prisma/client/*.dylib",
      "node_modules/prisma/**/*",
      "node_modules/.prisma/client/*.node",
      "prisma/**/*",
      "node_modules/@prisma/client/**/*",
      ".env.example",
      "node_modules/.prisma/client/*.so",
      "public/**/*"
    ]
  },
  "main": "dist/app.js"
}
